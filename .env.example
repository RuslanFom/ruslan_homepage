# Copy this file to `.env.local` for local `npm run dev` (Next.js loads .env.local automatically).

# hCaptcha (server): https://dashboard.hcaptcha.com/ — same account as site key in contact form
HCAPTCHA_SECRET_KEY=

# EmailJS — used by /api/send-contact-email (server → api.emailjs.com, avoids browser blockers)
# Prefer these on Vercel (not exposed to the client bundle):
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_TO_NAME=
EMAILJS_TO_EMAIL=

# Legacy names (still supported if server names above are empty)
NEXT_PUBLIC_EMAIL_SERVICE_ID=
NEXT_PUBLIC_EMAIL_TEMPLATE_ID=
NEXT_PUBLIC_EMAIL_USER_ID=
NEXT_PUBLIC_EMAIL_TO_NAME=
NEXT_PUBLIC_EMAIL_TO_EMAIL=
